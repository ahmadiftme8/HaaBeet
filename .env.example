# Neon Database Environment Variables
# Replace the values with your actual Neon project details

haabeetdb_VITE_NEON_AUTH_URL=https://your-neon-auth-url
haabeetdb_POSTGRES_URL_NO_SSL=postgresql://user:password@host:port/database
haabeetdb_PGHOST=your-neon-host
haabeetdb_PGHOST_UNPOOLED=your-neon-host-unpooled
haabeetdb_DATABASE_URL=postgresql://user:password@host:port/database
haabeetdb_PGPASSWORD=your-password
haabeetdb_NEON_AUTH_BASE_URL=https://your-neon-auth-base-url
haabeetdb_POSTGRES_HOST=your-postgres-host
haabeetdb_POSTGRES_USER=your-username
haabeetdb_POSTGRES_URL_NON_POOLING=postgresql://user:password@host:port/database